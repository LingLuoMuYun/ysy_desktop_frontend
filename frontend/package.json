{
  "name": "ysy-desktop-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "桌面智算 Electron desktop application",
  "author": "YSY Desktop Team",
  "type": "module",
  "main": "electron/main/index.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron:dev": "node scripts/run-electron-dev.cjs",
    "electron:preview": "pnpm run build && electron electron/main/index.js",
    "electron:package": "pnpm run build && electron-builder",
    "electron:package:win": "pnpm run build && electron-builder --win",
    "electron:package:mac": "pnpm run build && electron-builder --mac",
    "electron:package:linux": "pnpm run build && electron-builder --linux",
    "typecheck": "tsc -b"
  },
  "build": {
    "appId": "com.ysy.desktop",
    "productName": "桌面智算",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "resources/**/*",
      "!electron/main/index-simple.mjs",
      "!electron/main/index-test.mjs",
      "!electron/main/index.d.ts",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "桌面智算",
      "installerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "uninstallDisplayName": "桌面智算",
      "menuCategory": "桌面智算",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1"
  }
}
